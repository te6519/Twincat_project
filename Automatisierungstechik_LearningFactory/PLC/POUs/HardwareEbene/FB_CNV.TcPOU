<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_CNV" Id="{85a3c084-5822-445d-88cd-b30dbd71fba2}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_CNV
VAR_INPUT
	bEnable : BOOL;
	bExecute : BOOL;
	bHalt : BOOL;
	rVel : REAL;
	
	eState : EFoerderband;
END_VAR
VAR_OUTPUT
END_VAR
VAR
	nState : INT :=0;
	mcPower : MC_Power;
	mcReset : MC_Reset;
	mcVelocity : MC_MoveVelocity;
	mcHalt : MC_Halt;
	ErrorID: INT;
	bStop : Bool;
	mcStop: MC_Stop;
END_VAR

VAR_IN_OUT 
	ax : Axis_Ref;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[mcHalt(
	Axis:= ax, 
	Execute:= , 
	Deceleration:= , 
	Jerk:= , 
	BufferMode:= , 
	Options:= , 
	Done=> , 
	Busy=> , 
	Active=> , 
	CommandAborted=> , 
	Error=> , 
	ErrorID=> );
	
mcPower(
	Axis:= ax, 
	Enable:= , 
	Enable_Positive:= , 
	Enable_Negative:= , 
	Override:= , 
	BufferMode:= , 
	Options:= , 
	Status=> , 
	Busy=> , 
	Error=> , 
	ErrorID=> );
	
mcReset(
	Axis:= ax, 
	Execute:= , 
	Done=> , 
	Busy=> , 
	Error=> , 
	ErrorID=> );
	
mcVelocity(
	Axis:= ax, 
	Execute:= , 
	Velocity:= rVel, 
	Acceleration:= , 
	Deceleration:= , 
	Jerk:= , 
	Direction:= , 
	BufferMode:= , 
	Options:= , 
	InVelocity=> , 
	Busy=> , 
	Active=> , 
	CommandAborted=> , 
	Error=> , 
	ErrorID=> );

ax.ReadStatus();

bStop := ifc_HW.bStop;
IF bStop THEN
	nState := 80; //Stop CNV
END_IF

IF ax.Status.Error THEN 
	nState := 99;
ELSIF NOT bEnable THEN 
	nState := 0;
END_IF

mcStop(
	Axis:= ax, 
	Execute:= , 
	Deceleration:= , 
	Jerk:= , 
	Options:= , 
	Done=> , 
	Busy=> , 
	Active=> , 
	CommandAborted=> , 
	Error=> , 
	ErrorID=> );

CASE eState OF
	EFoerderband.Off: // OFF
	
		mcReset.Execute := FALSE;
		mcPower.Enable := FALSE;
		mcPower.Enable_Positive := FALSE;
		mcVelocity.Execute := FALSE;
		mcHalt.Execute := FALSE;
		
		
		IF ax.Status.Error THEN 
			nState := 99;
		ELSIF bEnable THEN 
			nState := 1;
		END_IF
	
	EFoerderband.init: //INIT
		
		mcPower.Enable := TRUE;
		mcPower.Enable_Positive := FALSE;
		mcReset.Execute := FALSE;
		mcVelocity.Execute := FALSE;
		mcHalt.Execute := FALSE;
	
		IF mcPower.Status THEN 
			nState :=2;
		END_IF
		
	EFoerderband.Ready: //Ready
		mcPower.Enable := TRUE;
		mcPower.Enable_Positive := FALSE;
		mcReset.Execute := FALSE;
		mcVelocity.Execute := FALSE;
		mcHalt.Execute := FALSE;
		
		IF bExecute THEN 
			nState :=3;
		END_IF
	
	EFoerderband.CNV_on:// CNV an
		mcPower.Enable := TRUE;
		mcPower.Enable_Positive := TRUE;
		mcReset.Execute := FALSE;
		mcVelocity.Execute := TRUE;
		mcHalt.Execute := FALSE;
		
		IF bHalt THEN 
			nState :=4;
		END_IF
	
	EFoerderband.CNV_aus: // CNV aus
		mcPower.Enable := TRUE;
		mcPower.Enable_Positive := TRUE;
		mcReset.Execute := FALSE;
		mcVelocity.Execute := FALSE;
		mcHalt.Execute := TRUE;
		
		IF mcHalt.Done THEN 
			nState :=5;
		END_IF
	
	EFoerderband.Done: // DONE
		mcPower.Enable := TRUE;
		mcPower.Enable_Positive := TRUE;
		mcReset.Execute := FALSE;
		mcVelocity.Execute := FALSE;
		mcHalt.Execute := FALSE;
		
		IF NOT bExecute AND NOT bHalt THEN 
			nState :=2;
		END_IF
	
	EFoerderband.ErrorState: // ERROR 
		mcPower.Enable := FALSE;
		mcPower.Enable_Positive := FALSE;
		mcReset.Execute := FALSE;
		mcVelocity.Execute := FALSE;
		mcHalt.Execute := FALSE;
		
		IF bEnable THEN 
			nState :=100;
		END_IF
	
	80: //Stop CNV
	mcVelocity.Execute := FALSE;
	mcHalt.Execute := FALSE;
	mcStop.Execute := TRUE;
	
	IF mcStop.Done AND NOT bStop THEN
		nState := 81;
	END_IF
	
	81: //RE-INIT //noch überarbeiten mit e state und 
	mcVelocity.Execute := FALSE;
	mcHalt.Execute := FALSE;
	mcStop.Execute := FALSE;
	mcReset.Execute := TRUE; 
	
	
	EFoerderband.Resolve: // Resolve
		mcPower.Enable := TRUE;
		mcPower.Enable_Positive := TRUE;
		mcReset.Execute := FALSE;
		mcVelocity.Execute := FALSE;
		mcHalt.Execute := FALSE;
	
	IF mcReset.Done THEN 
			nState :=3;
		END_IF
END_CASE]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>